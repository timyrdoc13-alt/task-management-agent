KAITEN_BASE_URL=https://YOUR-WORKSPACE.kaiten.ru
KAITEN_API_TOKEN=PASTE_BEARER_TOKEN_HERE
KAITEN_DEFAULT_BOARD_ID=
KAITEN_DEFAULT_COLUMN_ID=
KAITEN_DEFAULT_LANE_ID=
# Parent column ids from GET /boards/{id}/columns (subcolumns auto-included in reports)
KAITEN_COL_QUEUE=
KAITEN_COL_WIP=
# Optional: explicit move target if auto leaf pick is wrong (e.g. 6128315)
# KAITEN_COL_WIP_MOVE=
# Optional: extra column ids per bucket, comma-separated (e.g. review subcolumn)
# KAITEN_COL_WIP_IDS=
KAITEN_COL_DONE=
# Роль для POST /cards/{id}/time-logs (ID из GET /api/v1/user-roles)
KAITEN_TIMELOG_ROLE_ID=

TZ=Europe/Moscow

# Docker Compose (см. docker-compose.yml)
# KAITEN_RUNTIME_DIR=/data/runtime
# KAITEN_ARTIFACTS_DIR=/data/artifacts

# Telegram bot
TG_BOT_TOKEN=
# Доп. whitelist (объединяется с config/telegram_users.yaml, role=editor)
TG_ALLOWED_USERS=
TG_ALLOWED_CHATS=
# Уведомления админу при создании задачи (тихий push в TG)
TG_ADMIN_NOTIFY_IDS=
TG_NOTIFY_ON_CARD_CREATE=true
TG_NOTIFY_SKIP_SELF=true
# Уведомление исполнителю в TG (нужен telegram_id в config/telegram_users.yaml)
TG_NOTIFY_ASSIGNEE=true
TG_NOTIFY_ASSIGNEE_SILENT=false
TG_ADMIN_MACOS_NOTIFY=true

# DeepSeek (классификация + ресёрч)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_SMART=deepseek-v4-pro

# Авто-ресёрч
AUTO_RESEARCH_ENABLED=true
AUTO_RESEARCH_MIN_CONFIDENCE=0.75
AUTO_RESEARCH_MAX_FETCHES=12
AUTO_RESEARCH_WALL_TIME_SEC=480
RESEARCH_ATTACH_FORMAT=docx
RESEARCH_TWO_PASS=true
RESEARCH_MAX_QUERIES=10
RESEARCH_RESULTS_PER_QUERY=4
RESEARCH_CHARS_PER_PAGE=6000
RESEARCH_CHARS_PER_SOURCE=4500
RESEARCH_MAX_SOURCES_IN_PROMPT=12
RESEARCH_SYNTH_MAX_TOKENS=10000
RESEARCH_SYNTH_CONTINUE_ROUNDS=2
RESEARCH_SYNTH_CONTINUE_MAX_TOKENS=4500
RESEARCH_SYNTH_MAX_SOURCES_WITH_FACTS=8
RESEARCH_SYNTH_CHARS_WITH_FACTS=2000
RESEARCH_SYNTH_FALLBACK_MAX_TOKENS=4000
RESEARCH_SYNTH_FALLBACK_CHARS=2000
RESEARCH_SYNTH_TIMEOUT_SEC=240
RESEARCH_STREAM_TLDR=true
RESEARCH_TLDR_MAX_TOKENS=900
RESEARCH_TLDR_TIMEOUT_SEC=90
RESEARCH_FETCH_WORKERS=4
TG_STREAM_EDIT_INTERVAL_SEC=1.2
DEEPSEEK_MAX_RETRIES=5
RESEARCH_CHARTS_ENABLED=true
KROKI_BASE_URL=https://kroki.io

# Фаза 2 — платный поиск (надёжнее DuckDuckGo HTML)
# SERPER_API_KEY=   # https://serper.dev — Google organic JSON
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=

# Фазе 2 — лучшее извлечение текста со страниц
# JINA_READER_API_KEY=

# Agent harness policy (Telegram)
KAITEN_AGENT_AUTO_CARDS=true
# true = всегда превью+правки перед create (игнорирует auto_cards)
KAITEN_TASK_ALWAYS_PREVIEW=false
KAITEN_AGENT_AUTO_RESEARCH=true
# steps | edit | both — прогресс ресёрча в TG (steps надёжнее edit_message)
TG_RESEARCH_PROGRESS_MODE=steps
KAITEN_AGENT_NO_AUTOCOMMENT=false
TG_ALLOWED_USERS=
# TG_ALLOWED_CHATS=  # optional: allow whole group by chat_id

# Rate limits (PERMISSIONS.md)
RATE_KAITEN_READS_PER_MIN=60
RATE_KAITEN_WRITES_PER_RUN=8
RATE_WEB_FETCHES_PER_RUN=10
RATE_ARTIFACTS_PER_RUN=3
KAITEN_HTTP_MAX_RETRIES=3
KAITEN_AGENT_LOG_LEVEL=info
